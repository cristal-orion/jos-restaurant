---
import Base from '../../layouts/Base.astro';
import LogoJose from '../LogoJose.astro';
import LanguageSwitcher from '../LanguageSwitcher.astro';
import { localizedPath, type Locale } from '../../i18n/utils';

interface Props {
  lang: Locale;
}

const { lang } = Astro.props;

const dict = {
  it: {
    meta: {
      title: "Villa Guerra & Josè | Eventi e Prestigio a Torre del Greco, Miglio d'Oro",
      description:
        "Tenuta Villa Guerra: dimora storica del '700 nel Miglio d'Oro, a Torre del Greco, per eventi privati, business e cerimonie.",
      venueDescription:
        "Dimora storica del '700 nel Miglio d'Oro per eventi privati, cerimonie e business.",
    },
    nav: { ristorante: 'Ristorante', eventi: 'Eventi', prenota: 'Prenota Ora' },
    aria: { openMenu: 'Apri menu', closeMenu: 'Chiudi menu' },
    hero: {
      eyebrow: 'Dimora del ’700 · Miglio d’Oro',
      h1: 'Il prestigio di una dimora del&nbsp;’700 per i tuoi momenti indimenticabili',
      subtitle: 'Sale eleganti e giardini sul Golfo di Napoli per eventi privati, business e cerimonie.',
      cta1: 'Scopri le Sale',
      cta2: 'Inizia a Progettare',
    },
    sale: {
      carouselAria: 'Gli spazi della Tenuta Villa Guerra',
      dotsAria: 'Vai allo spazio',
      prevAria: 'Spazio precedente',
      nextAria: 'Spazio successivo',
      itemLabel: 'Spazio',
      slides: [
        { src: 'tenuta-facciata.webp', alt: 'Facciata settecentesca della Tenuta Villa Guerra immersa nel giardino', caption: 'La facciata del ’700' },
        { src: 'tenuta-sala-verde.jpg', alt: 'Elegante sala da pranzo della Tenuta con tavolo imperiale e lampadari in cristallo', caption: 'La sala da pranzo' },
        { src: 'tenuta-salone.webp', alt: 'Salone per eventi della Tenuta con soffitto a volta e bancone allestito', caption: 'Il salone per gli eventi' },
        { src: 'tenuta-portico.webp', alt: 'Porticato a volta della Tenuta Villa Guerra', caption: 'I porticati' },
        { src: 'tenuta-terrazza.webp', alt: 'Terrazza esterna coperta della Tenuta con tavoli rotondi affacciata sul giardino', caption: 'La terrazza' },
        { src: 'tenuta-giardino.webp', alt: 'Vialetto nel giardino della Tenuta Villa Guerra tra il verde e il pergolato', caption: 'I giardini' },
        { src: 'tenuta-ricevimento.jpg', alt: "Tavolo del ricevimento allestito all'aperto nel giardino della Tenuta", caption: 'Allestimenti su misura' },
      ],
      heading: 'Echi di Storia e Raffinatezza',
      p: "Le nostre sale conservano l'anima aristocratica della Napoli del XVIII secolo. Ogni dettaglio, dai lampadari in cristallo ai marmi pregiati, è stato restaurato per accogliere eventi che richiedono un'atmosfera di rara bellezza.",
      feature1: { title: 'Sala del Trono', desc: 'Ambienti curati nei dettagli e una vista mozzafiato sul Golfo di Napoli.' },
      feature2: { title: 'I Giardini Pensili', desc: 'Uno spazio esterno immerso nel verde tra pini secolari e profumo di mare.' },
    },
    eventi: {
      heading: 'Un palcoscenico per ogni emozione',
      intro: 'Tre modi di vivere la Tenuta, ognuno con il suo ritmo e la sua scenografia.',
      privati: {
        alt: 'Tavoli allestiti nei giardini della Tenuta per un evento privato',
        title: 'Eventi Privati',
        desc: 'Compleanni, anniversari e feste private: la Tenuta diventa la vostra dimora per un giorno, con la riservatezza di una casa nobiliare.',
        cta: 'Richiedi un sopralluogo',
      },
      business: {
        alt: 'Sala allestita per un evento aziendale alla Tenuta Villa Guerra',
        title: 'Business',
        desc: 'Convegni, gala dinner e lanci di prodotto in una cornice che comunica autorevolezza.',
        cta: 'Organizza',
      },
      cerimonie: {
        alt: 'Il parco della Tenuta Villa Guerra per cerimonie e ricorrenze',
        title: 'Cerimonie',
        desc: 'Battesimi, comunioni e ricorrenze speciali, celebrate tra saloni d’epoca e giardini affacciati sul Golfo.',
        cta: 'Prenota',
      },
    },
    form: {
      heading: 'Progetta il tuo evento',
      intro: 'Lasciaci i tuoi riferimenti e la tua idea. La nostra Event Manager ti contatterà per trasformarla in realtà.',
      nomeLabel: 'Nome e Cognome',
      nomePlaceholder: 'Mario Rossi',
      emailLabel: 'Email',
      emailPlaceholder: 'nome@esempio.it',
      tipoLabel: 'Tipo di evento',
      tipoSelect: 'Seleziona…',
      tipoPrivato: 'Evento privato',
      tipoBusiness: 'Business',
      tipoCerimonia: 'Cerimonia',
      dataLabel: 'Data prevista',
      messaggioLabel: 'La tua visione',
      messaggioPlaceholder: 'Raccontaci la tua idea per l’evento…',
      submit: 'Invia Richiesta',
    },
    footer: {
      villaHeading: 'Villa Guerra',
      address: 'Via Nazionale, 414',
      addressLine2: '80059 Torre del Greco (NA) - Italia',
      esplora: 'Esplora',
      progettaEvento: 'Progetta un evento',
      ristoranteJose: 'Ristorante Josè',
      prenotaTavolo: 'Prenota un tavolo',
      joseHeading: 'Josè Restaurant',
      joseQuote: '«Il Vesuvio tra le mani»',
      copyright: '© 2024 Tenuta Villa Guerra & Josè Restaurant. Napoli.',
    },
  },
  en: {
    meta: {
      title: "Villa Guerra & Josè | Events and Prestige in Torre del Greco, Miglio d'Oro",
      description:
        "Tenuta Villa Guerra: a historic 18th-century estate in the Miglio d'Oro, Torre del Greco, for private events, business and celebrations.",
      venueDescription:
        'Historic 18th-century estate in the Miglio d’Oro for private events, celebrations and business.',
    },
    nav: { ristorante: 'Restaurant', eventi: 'Events', prenota: 'Book Now' },
    aria: { openMenu: 'Open menu', closeMenu: 'Close menu' },
    hero: {
      eyebrow: '18th-Century Estate · Miglio d’Oro',
      h1: 'The prestige of an&nbsp;18th-century estate for your unforgettable moments',
      subtitle: 'Elegant halls and gardens overlooking the Gulf of Naples for private events, business and celebrations.',
      cta1: 'Discover the Halls',
      cta2: 'Start Planning',
    },
    sale: {
      carouselAria: 'The spaces of Tenuta Villa Guerra',
      dotsAria: 'Go to space',
      prevAria: 'Previous space',
      nextAria: 'Next space',
      itemLabel: 'Space',
      slides: [
        { src: 'tenuta-facciata.webp', alt: '18th-century facade of Tenuta Villa Guerra surrounded by the garden', caption: 'The 18th-century facade' },
        { src: 'tenuta-sala-verde.jpg', alt: 'Elegant dining hall of the Tenuta with imperial table and crystal chandeliers', caption: 'The dining hall' },
        { src: 'tenuta-salone.webp', alt: 'Event hall of the Tenuta with vaulted ceiling and set-up bar', caption: 'The event hall' },
        { src: 'tenuta-portico.webp', alt: 'Vaulted portico of Tenuta Villa Guerra', caption: 'The porticoes' },
        { src: 'tenuta-terrazza.webp', alt: "Covered outdoor terrace of the Tenuta with round tables overlooking the garden", caption: 'The terrace' },
        { src: 'tenuta-giardino.webp', alt: "Pathway in the garden of Tenuta Villa Guerra amid greenery and pergola", caption: 'The gardens' },
        { src: 'tenuta-ricevimento.jpg', alt: "Reception table set outdoors in the Tenuta's garden", caption: 'Bespoke setups' },
      ],
      heading: 'Echoes of History and Refinement',
      p: "Our halls preserve the aristocratic soul of 18th-century Naples. Every detail, from the crystal chandeliers to the fine marble, has been restored to host events that call for an atmosphere of rare beauty.",
      feature1: { title: 'The Throne Room', desc: 'Meticulously detailed rooms with a breathtaking view of the Gulf of Naples.' },
      feature2: { title: 'The Hanging Gardens', desc: 'An outdoor space immersed in greenery, among century-old pines and the scent of the sea.' },
    },
    eventi: {
      heading: 'A stage for every emotion',
      intro: 'Three ways to experience the Tenuta, each with its own rhythm and setting.',
      privati: {
        alt: "Tables set up in the Tenuta's gardens for a private event",
        title: 'Private Events',
        desc: 'Birthdays, anniversaries and private parties: the Tenuta becomes your home for a day, with the privacy of a noble residence.',
        cta: 'Request a Site Visit',
      },
      business: {
        alt: 'Hall set up for a corporate event at Tenuta Villa Guerra',
        title: 'Business',
        desc: 'Conferences, gala dinners and product launches in a setting that conveys authority.',
        cta: 'Get Started',
      },
      cerimonie: {
        alt: 'The park of Tenuta Villa Guerra for ceremonies and special occasions',
        title: 'Ceremonies',
        desc: 'Baptisms, first communions and special occasions, celebrated among period halls and gardens overlooking the Gulf.',
        cta: 'Book Now',
      },
    },
    form: {
      heading: 'Plan Your Event',
      intro: 'Leave us your details and your idea. Our Event Manager will contact you to make it a reality.',
      nomeLabel: 'Full Name',
      nomePlaceholder: 'John Smith',
      emailLabel: 'Email',
      emailPlaceholder: 'name@example.com',
      tipoLabel: 'Event Type',
      tipoSelect: 'Select…',
      tipoPrivato: 'Private event',
      tipoBusiness: 'Business',
      tipoCerimonia: 'Ceremony',
      dataLabel: 'Expected Date',
      messaggioLabel: 'Your Vision',
      messaggioPlaceholder: 'Tell us about your idea for the event…',
      submit: 'Send Request',
    },
    footer: {
      villaHeading: 'Villa Guerra',
      address: 'Via Nazionale, 414',
      addressLine2: '80059 Torre del Greco (NA) - Italy',
      esplora: 'Explore',
      progettaEvento: 'Plan an Event',
      ristoranteJose: 'Josè Restaurant',
      prenotaTavolo: 'Book a Table',
      joseHeading: 'Josè Restaurant',
      joseQuote: '«Vesuvius in your hands»',
      copyright: '© 2024 Tenuta Villa Guerra & Josè Restaurant. Naples.',
    },
  },
} as const;

const t = dict[lang];

const venueSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'EventVenue'],
  name: 'Tenuta Villa Guerra',
  image: 'https://tenutavillaguerra.it/images/villa-grand.webp',
  url: new URL(localizedPath(lang, new URL('/tenuta', Astro.site)), Astro.site).toString(),
  telephone: '+390818836298',
  description: t.meta.venueDescription,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Via Nazionale, 414',
    addressLocality: 'Torre del Greco',
    addressRegion: 'NA',
    postalCode: '80059',
    addressCountry: 'IT',
  },
};

const homeHref = localizedPath(lang, new URL('/', Astro.site));
const joseHref = localizedPath(lang, new URL('/jose', Astro.site));
const tenutaHref = localizedPath(lang, new URL('/tenuta', Astro.site));
---

<Base
  title={t.meta.title}
  description={t.meta.description}
  bodyClass="bg-surface text-on-surface font-body-md selection:bg-antique-gold/30"
  schema={venueSchema}
  lang={lang}
>
  <!-- TopAppBar -->
  <header
    class="fixed top-0 w-full flex justify-between items-center px-margin-mobile md:px-margin-desktop h-20 bg-surface/90 backdrop-blur-md border-b border-outline-variant/30 z-50"
  >
    <a
      href={homeHref}
      class="flex items-center gap-2 sm:gap-2.5 whitespace-nowrap"
      aria-label="Villa Guerra & Josè — home"
    >
      <span
        class="font-headline-md text-xl sm:text-headline-md text-primary uppercase tracking-widest"
        >Villa Guerra &amp;</span
      >
      <LogoJose class="h-8 sm:h-10 w-auto text-primary" />
    </a>
    <nav class="hidden md:flex items-center gap-8">
      <a
        class="text-label-sm font-label-sm text-on-surface-variant hover:text-primary transition-colors"
        href={joseHref}>{t.nav.ristorante}</a
      >
      <a
        class="text-label-sm font-label-sm text-primary border-b-2 border-antique-gold pb-1"
        href={tenutaHref}
        aria-current="page">{t.nav.eventi}</a
      >
      {/* "Cantina" nascosta dal nav su richiesta: la pagina /cantina resta online ma non linkata — togliere il commento alla riga sotto per rimostrarla. "Storia" rimossa: nessun contenuto. */}
      {/* <a class="text-label-sm font-label-sm text-on-surface-variant hover:text-primary transition-colors" href="/cantina">Cantina</a> */}
      <LanguageSwitcher lang={lang} class="text-on-surface-variant" />
    </nav>
    <div class="flex items-center gap-6">
      <a
        href="#contatti"
        class="hidden sm:inline-block bg-antique-gold text-silk-white px-6 py-2 uppercase font-label-sm text-label-sm tracking-widest hover:bg-primary transition-colors duration-300 ease-out active:scale-95"
      >
        {t.nav.prenota}
      </a>
      <button
        id="menu-toggle"
        class="md:hidden material-symbols-outlined text-primary cursor-pointer leading-none"
        aria-label={t.aria.openMenu}
        aria-controls="mobile-menu"
        aria-expanded="false"
        data-label-open={t.aria.openMenu}
        data-label-close={t.aria.closeMenu}
        >menu</button
      >
    </div>

    <!-- Menu mobile -->
    <div
      id="mobile-menu"
      class="md:hidden fixed top-20 left-0 w-full bg-surface/95 backdrop-blur-md border-b border-outline-variant/30 z-40 hidden flex-col px-margin-mobile md:px-margin-desktop py-6 gap-1 shadow-lg"
    >
      <a
        class="text-label-sm font-label-sm text-on-surface-variant py-3 border-b border-outline-variant/20"
        href={joseHref}>{t.nav.ristorante}</a
      >
      <a
        class="text-label-sm font-label-sm text-primary py-3 border-b border-outline-variant/20"
        href={tenutaHref}
        aria-current="page">{t.nav.eventi}</a
      >
      {/* "Cantina" e "Storia" nascoste anche dal menu mobile (vedi nav desktop). */}
      {/* <a class="text-label-sm font-label-sm text-on-surface-variant py-3 border-b border-outline-variant/20" href="/cantina">Cantina</a> */}
      <div class="py-3 border-b border-outline-variant/20">
        <LanguageSwitcher lang={lang} class="text-on-surface-variant" />
      </div>
      <a
        href="#contatti"
        class="mt-4 bg-antique-gold text-silk-white px-6 py-3 text-center uppercase font-label-sm text-label-sm tracking-widest hover:bg-primary transition-colors"
        >{t.nav.prenota}</a
      >
    </div>
  </header>

  <main class="pt-20">
    <!-- Hero -->
    <section
      class="relative h-[92vh] min-h-[600px] flex items-end overflow-hidden"
    >
      <div class="absolute inset-0 z-0">
        <img
          alt="Facciata settecentesca della Tenuta Villa Guerra"
          class="w-full h-full object-cover scale-105"
          src="/images/villa-grand.webp"
          fetchpriority="high"
        />
        <div
          class="absolute inset-0 bg-gradient-to-tr from-black/75 via-black/35 to-transparent"
        >
        </div>
      </div>
      <div
        class="relative z-10 w-full px-margin-mobile md:px-margin-desktop pb-20 md:pb-28"
      >
        <div class="max-w-container-max mx-auto">
          <p
            class="font-label-sm text-label-sm text-antique-gold tracking-[0.3em] uppercase mb-6"
          >
            {t.hero.eyebrow}
          </p>
          <h1
            class="font-headline-display text-[2.25rem] sm:text-5xl md:text-headline-display text-silk-white text-shadow-elegant max-w-3xl leading-[1.05] break-words"
            set:html={t.hero.h1}
          />
          <p
            class="mt-8 font-body-lg text-body-lg text-silk-white/80 max-w-xl"
          >
            {t.hero.subtitle}
          </p>
          <div class="mt-10 flex flex-col sm:flex-row gap-4">
            <a
              class="inline-flex items-center justify-center whitespace-nowrap bg-antique-gold text-silk-white px-10 py-4 uppercase font-label-sm text-label-sm tracking-widest hover:bg-silk-white hover:text-antique-gold transition-colors duration-300 ease-out"
              href="#sale"
            >
              {t.hero.cta1}
            </a>
            <a
              class="inline-flex items-center justify-center whitespace-nowrap border border-silk-white text-silk-white px-10 py-4 uppercase font-label-sm text-label-sm tracking-widest hover:bg-silk-white/10 transition-colors duration-300 ease-out"
              href="#contatti"
            >
              {t.hero.cta2}
            </a>
          </div>
        </div>
      </div>
    </section>

    <!-- Le Sale -->
    <section
      class="py-24 px-margin-mobile md:px-margin-desktop bg-surface-container-low overflow-hidden"
      id="sale"
    >
      <div class="max-w-container-max mx-auto">
        <div class="flex flex-col lg:flex-row gap-20 items-center">
          <div class="w-full lg:w-1/2 relative">
            <div
              class="villa-outline absolute -top-8 -left-8 w-64 h-64 z-0 hidden lg:block"
            >
            </div>
            <!-- Carosello degli spazi della Tenuta -->
            <div class="relative z-10 shadow-2xl">
              <div class="aspect-[4/5] overflow-hidden bg-surface-container-high">
                <div
                  id="sale-carousel"
                  class="flex h-full w-full overflow-x-auto snap-x snap-mandatory no-scrollbar"
                  aria-roledescription="carosello"
                  aria-label={t.sale.carouselAria}
                  data-item-label={t.sale.itemLabel}
                  data-of-word={lang === 'en' ? 'of' : 'di'}
                  tabindex="0"
                >
                  {t.sale.slides.map((slide) => (
                    <figure class="relative m-0 snap-center shrink-0 w-full h-full">
                      <img
                        class="w-full h-full object-cover"
                        src={`/images/${slide.src}`}
                        alt={slide.alt}
                        loading="lazy"
                      />
                      <div class="absolute inset-x-0 bottom-0 h-1/3 bg-gradient-to-t from-black/70 to-transparent"></div>
                      <figcaption class="absolute bottom-4 left-4 z-10 font-label-sm text-label-sm uppercase tracking-widest text-silk-white">{slide.caption}</figcaption>
                    </figure>
                  ))}
                </div>
                <!-- controlli carosello -->
                <div class="absolute bottom-4 right-4 z-10 flex items-center gap-3">
                  <div
                    class="sale-dots flex items-center gap-1.5"
                    role="tablist"
                    aria-label={t.sale.dotsAria}
                  >
                  </div>
                  <div class="flex gap-2">
                    <button
                      type="button"
                      data-carousel="prev"
                      aria-label={t.sale.prevAria}
                      class="grid place-items-center h-9 w-9 bg-lava-stone/70 backdrop-blur-sm text-silk-white hover:bg-antique-gold hover:text-lava-stone transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-silk-white"
                    >
                      <span class="material-symbols-outlined text-[20px] leading-none">chevron_left</span>
                    </button>
                    <button
                      type="button"
                      data-carousel="next"
                      aria-label={t.sale.nextAria}
                      class="grid place-items-center h-9 w-9 bg-lava-stone/70 backdrop-blur-sm text-silk-white hover:bg-antique-gold hover:text-lava-stone transition-colors focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-silk-white"
                    >
                      <span class="material-symbols-outlined text-[20px] leading-none">chevron_right</span>
                    </button>
                  </div>
                </div>
              </div>
            </div>
          </div>
          <div class="w-full lg:w-1/2">
            <h2 class="font-headline-lg text-headline-lg text-primary mb-8">
              {t.sale.heading}
            </h2>
            <p
              class="font-body-lg text-body-lg text-on-surface-variant mb-8 max-w-xl"
            >
              {t.sale.p}
            </p>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-8 mt-12">
              <div>
                <h4 class="font-headline-md text-headline-md text-antique-gold mb-2">
                  {t.sale.feature1.title}
                </h4>
                <p class="text-on-surface-variant">
                  {t.sale.feature1.desc}
                </p>
              </div>
              <div>
                <h4 class="font-headline-md text-headline-md text-antique-gold mb-2">
                  {t.sale.feature2.title}
                </h4>
                <p class="text-on-surface-variant">
                  {t.sale.feature2.desc}
                </p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Eventi -->
    <section class="py-24 md:py-28 px-margin-mobile md:px-margin-desktop bg-surface-container-low">
      <div class="max-w-container-max mx-auto">
        <div class="max-w-2xl mb-14">
          <h2 class="font-headline-lg text-4xl sm:text-headline-lg text-primary leading-tight break-words">
            {t.eventi.heading}
          </h2>
          <p class="mt-4 font-body-lg text-body-lg text-on-surface-variant">
            {t.eventi.intro}
          </p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-12 lg:auto-rows-fr gap-gutter">
          <!-- Eventi Privati — feature grande (core business) -->
          <article
            class="group relative lg:col-span-7 lg:row-span-2 overflow-hidden villa-outline min-h-[460px]"
          >
            <img
              alt={t.eventi.privati.alt}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
              src="/images/tenuta-privati.webp"
            />
            <div
              class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/25 to-transparent"
            >
            </div>
            <div class="relative h-full flex flex-col justify-end p-8 md:p-10">
              <h3 class="font-headline-display text-headline-lg text-silk-white">
                {t.eventi.privati.title}
              </h3>
              <p class="mt-3 max-w-md font-body-md text-body-md text-silk-white/85">
                {t.eventi.privati.desc}
              </p>
              <a
                class="mt-6 inline-flex items-center gap-2 text-antique-gold font-label-sm text-label-sm uppercase tracking-widest hover:text-silk-white transition-colors duration-300 ease-out"
                href="#contatti"
              >
                {t.eventi.privati.cta}
                <span
                  class="material-symbols-outlined transition-transform duration-300 ease-out group-hover:translate-x-1"
                  >arrow_forward</span
                >
              </a>
            </div>
          </article>

          <!-- Business — card orizzontale -->
          <article
            class="group lg:col-span-5 flex flex-col sm:flex-row overflow-hidden villa-outline bg-clotted-cream"
          >
            <div class="sm:w-2/5 aspect-[4/3] sm:aspect-auto overflow-hidden">
              <img
                alt={t.eventi.business.alt}
                class="w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.04]"
                src="/images/tenuta-business.webp"
              />
            </div>
            <div class="flex-1 p-7 flex flex-col justify-center">
              <h3 class="font-headline-md text-headline-md text-primary">{t.eventi.business.title}</h3>
              <p class="mt-2 font-body-md text-body-md text-on-surface-variant">
                {t.eventi.business.desc}
              </p>
              <a
                class="mt-4 inline-flex items-center gap-2 text-antique-gold font-label-sm text-label-sm uppercase tracking-widest hover:text-primary transition-colors duration-300 ease-out"
                href="#contatti"
              >
                {t.eventi.business.cta}
                <span
                  class="material-symbols-outlined transition-transform duration-300 ease-out group-hover:translate-x-1"
                  >arrow_forward</span
                >
              </a>
            </div>
          </article>

          <!-- Cerimonie — card orizzontale -->
          <article
