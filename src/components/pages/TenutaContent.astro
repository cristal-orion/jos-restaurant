    <!-- CTA / Form -->
    <section class="py-24 px-margin-mobile md:px-margin-desktop bg-clotted-cream relative" id="contatti">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="font-headline-lg text-headline-lg text-primary mb-4">
          {t.form.heading}
        </h2>
        <p class="font-body-lg text-body-lg text-on-surface-variant mb-12">
          {t.form.intro}
        </p>
        <form class="space-y-10 text-left">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div>
              <label
                for="evt-nome"
                class="block text-label-sm font-label-sm text-on-surface-variant mb-2"
                >{t.form.nomeLabel}</label
              >
              <input
                id="evt-nome"
                name="nome"
                type="text"
                autocomplete="name"
                required
                placeholder={t.form.nomePlaceholder}
                class="w-full bg-transparent border-t-0 border-l-0 border-r-0 border-b border-antique-gold focus:ring-0 focus:border-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-antique-gold px-0 py-3 placeholder:text-on-surface-variant/50 font-body-md"
              />
            </div>
            <div>
              <label
                for="evt-email"
                class="block text-label-sm font-label-sm text-on-surface-variant mb-2"
                >{t.form.emailLabel}</label
              >
              <input
                id="evt-email"
                name="email"
                type="email"
                autocomplete="email"
                required
                placeholder={t.form.emailPlaceholder}
                class="w-full bg-transparent border-t-0 border-l-0 border-r-0 border-b border-antique-gold focus:ring-0 focus:border-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-antique-gold px-0 py-3 placeholder:text-on-surface-variant/50 font-body-md"
              />
            </div>
          </div>
          <div class="grid grid-cols-1 md:grid-cols-2 gap-10">
            <div>
              <label
                for="evt-tipo"
                class="block text-label-sm font-label-sm text-on-surface-variant mb-2"
                >{t.form.tipoLabel}</label
              >
              <select
                id="evt-tipo"
                name="tipo"
                required
                class="w-full bg-transparent border-t-0 border-l-0 border-r-0 border-b border-antique-gold focus:ring-0 focus:border-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-antique-gold px-0 py-3 font-body-md"
              >
                <option value="">{t.form.tipoSelect}</option>
                <option value="privato">{t.form.tipoPrivato}</option>
                <option value="business">{t.form.tipoBusiness}</option>
                <option value="cerimonia">{t.form.tipoCerimonia}</option>
              </select>
            </div>
            <div>
              <label
                for="evt-data"
                class="block text-label-sm font-label-sm text-on-surface-variant mb-2"
                >{t.form.dataLabel}</label
              >
              <input
                id="evt-data"
                name="data"
                type="date"
                class="w-full bg-transparent border-t-0 border-l-0 border-r-0 border-b border-antique-gold focus:ring-0 focus:border-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-antique-gold px-0 py-3 font-body-md"
              />
            </div>
          </div>
          <div>
            <label
              for="evt-messaggio"
              class="block text-label-sm font-label-sm text-on-surface-variant mb-2"
              >{t.form.messaggioLabel}</label
            >
            <textarea
              id="evt-messaggio"
              name="messaggio"
              rows="4"
              placeholder={t.form.messaggioPlaceholder}
              class="w-full bg-transparent border-t-0 border-l-0 border-r-0 border-b border-antique-gold focus:ring-0 focus:border-primary focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-antique-gold px-0 py-3 placeholder:text-on-surface-variant/50 font-body-md"
            ></textarea>
          </div>
          <div class="text-center">
            <button
              class="bg-primary text-silk-white px-16 py-5 uppercase font-label-sm text-label-sm tracking-[0.2em] hover:bg-antique-gold transition-colors shadow-lg active:scale-95 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-4 focus-visible:outline-primary"
              type="submit"
            >
              {t.form.submit}
            </button>
          </div>
        </form>
      </div>
    </section>
  </main>

  <!-- Footer -->
  <footer
    class="w-full py-12 px-margin-mobile md:px-margin-desktop grid grid-cols-1 md:grid-cols-3 gap-gutter max-w-container-max mx-auto bg-surface-container-highest border-t border-outline-variant/30"
  >
    <div class="space-y-6">
      <div class="font-headline-md text-headline-md text-primary">{t.footer.villaHeading}</div>
      <p class="text-on-surface-variant text-body-md">
        {t.footer.address}<br />{t.footer.addressLine2}
      </p>
    </div>
    <div class="space-y-6">
      <h4 class="font-label-sm text-label-sm uppercase tracking-widest text-primary">
        {t.footer.esplora}
      </h4>
      <ul class="space-y-3">
        <li>
          <a
            class="text-on-surface-variant opacity-70 hover:opacity-100 transition-opacity font-label-sm text-label-sm"
            href="#contatti">{t.footer.progettaEvento}</a
          >
        </li>
        <li>
          <a
            class="text-on-surface-variant opacity-70 hover:opacity-100 transition-opacity font-label-sm text-label-sm"
            href={joseHref}>{t.footer.ristoranteJose}</a
          >
        </li>
        {/* "La Cantina" nascosta dal footer finché la pagina /cantina resta non pubblica. */}
        <li>
          <a
            class="text-on-surface-variant opacity-70 hover:opacity-100 transition-opacity font-label-sm text-label-sm"
            href={`${joseHref}#contatti`}>{t.footer.prenotaTavolo}</a
          >
        </li>
      </ul>
    </div>
    <div class="space-y-6 flex flex-col justify-between">
      <div>
        <h4 class="font-label-sm text-label-sm uppercase tracking-widest text-primary">
          {t.footer.joseHeading}
        </h4>
        <p class="text-on-surface-variant text-body-md italic mt-2">
          {t.footer.joseQuote}
        </p>
      </div>
      <p class="text-on-surface-variant opacity-70 font-label-sm text-label-sm">
        {t.footer.copyright}
      </p>
    </div>
  </footer>

  <script>
    // Reveal morbido delle sezioni allo scroll
    document.addEventListener('DOMContentLoaded', () => {
      // Con "riduci movimento" le sezioni restano subito visibili, senza dissolvenza
      if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('opacity-100', 'translate-y-0');
              entry.target.classList.remove('opacity-0', 'translate-y-10');
            }
          });
        },
        { threshold: 0.1 }
      );

      document.querySelectorAll('section').forEach((section) => {
        section.classList.add(
          'transition-all',
          'duration-1000',
          'opacity-0',
          'translate-y-10'
        );
        observer.observe(section);
      });
    });

    // Smooth scroll per le ancore interne
    document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]').forEach((anchor) => {
      anchor.addEventListener('click', function (this: HTMLAnchorElement, e) {
        const id = this.getAttribute('href');
        if (!id || id === '#') return;
        const target = document.querySelector(id);
        if (target) {
          e.preventDefault();
          const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          target.scrollIntoView({ behavior: reduce ? 'auto' : 'smooth' });
        }
      });
    });

    // Menu mobile (hamburger)
    const menuToggle = document.getElementById('menu-toggle');
    const mobileMenu = document.getElementById('mobile-menu');
    if (menuToggle && mobileMenu) {
      const setMenu = (open: boolean) => {
        mobileMenu.classList.toggle('hidden', !open);
        mobileMenu.classList.toggle('flex', open);
        menuToggle.textContent = open ? 'close' : 'menu';
        menuToggle.setAttribute('aria-expanded', String(open));
        menuToggle.setAttribute(
          'aria-label',
          open ? menuToggle.dataset.labelClose! : menuToggle.dataset.labelOpen!
        );
      };
      menuToggle.addEventListener('click', () => {
        setMenu(mobileMenu.classList.contains('hidden'));
      });
      mobileMenu.querySelectorAll('a').forEach((link) => {
        link.addEventListener('click', () => setMenu(false));
      });
    }

    // Carosello degli spazi (sezione "Le Sale")
    const carousel = document.getElementById('sale-carousel');
    const dotsWrap = document.querySelector<HTMLElement>('.sale-dots');
    const stage = carousel?.parentElement ?? null;
    if (carousel && dotsWrap && stage) {
      const itemLabel = carousel.dataset.itemLabel ?? '';
      const ofWord = carousel.dataset.ofWord ?? 'di';
      const slides = Array.from(carousel.children) as HTMLElement[];
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      const dots: HTMLButtonElement[] = [];
      let index = 0;
      let timer: number | undefined;

      const render = () => {
        dots.forEach((d, i) => {
          const active = i === index;
          d.style.width = active ? '18px' : '6px';
          d.classList.toggle('bg-silk-white', active);
          d.classList.toggle('bg-silk-white/50', !active);
          d.setAttribute('aria-selected', String(active));
        });
      };

      const go = (i: number, user = false) => {
        index = (i + slides.length) % slides.length;
        carousel.scrollTo({ left: slides[index].offsetLeft, behavior: reduce ? 'auto' : 'smooth' });
        render();
        if (user) restart();
      };

      const stop = () => {
        if (timer) {
          clearInterval(timer);
          timer = undefined;
        }
      };
      const start = () => {
        if (reduce) return;
        stop();
        timer = window.setInterval(() => go(index + 1), 5000);
      };
      const restart = () => {
        stop();
        start();
      };

      // puntini
      slides.forEach((_, i) => {
        const b = document.createElement('button');
        b.type = 'button';
        b.setAttribute('role', 'tab');
        b.setAttribute('aria-label', `${itemLabel} ${i + 1} ${ofWord} ${slides.length}`);
        b.className =
          'h-1.5 rounded-full bg-silk-white/50 transition-all focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-silk-white';
        b.style.width = '6px';
        b.addEventListener('click', () => go(i, true));
        dotsWrap.appendChild(b);
        dots.push(b);
      });

      // sincronizza i puntini con lo swipe/scroll manuale
      let raf: number | undefined;
      carousel.addEventListener('scroll', () => {
        if (raf) cancelAnimationFrame(raf);
        raf = requestAnimationFrame(() => {
          const i = Math.round(carousel.scrollLeft / carousel.clientWidth);
          if (i !== index) {
            index = i;
            render();
          }
        });
      });

      // frecce
      stage.querySelectorAll<HTMLButtonElement>('[data-carousel]').forEach((btn) => {
        btn.addEventListener('click', () =>
          go(index + (btn.dataset.carousel === 'next' ? 1 : -1), true)
        );
      });

      // tastiera (track focalizzabile)
      carousel.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowRight') {
          e.preventDefault();
          go(index + 1, true);
        } else if (e.key === 'ArrowLeft') {
          e.preventDefault();
          go(index - 1, true);
        }
      });

      // autoplay: in pausa su hover/focus/touch e a scheda nascosta; off con riduci-movimento
      ['mouseenter', 'focusin', 'touchstart'].forEach((ev) =>
        stage.addEventListener(ev, stop, { passive: true })
      );
      ['mouseleave', 'focusout'].forEach((ev) => stage.addEventListener(ev, start));
      document.addEventListener('visibilitychange', () => (document.hidden ? stop() : start()));

      render();
      start();
    }
  </script>
</Base>
